ANTHROPIC_API_KEY=your_api_key_here

# Database — auto-configured in Docker Compose
# For local dev without Docker: set ASO_LOCAL_DEV=1 to use SQLite
# DATABASE_URL=postgresql+asyncpg://aso:aso@localhost:5432/aso
# ASO_LOCAL_DEV=1

# Tester microservice (auto-configured in Docker Compose)
# TOOL_RUNNER_URL=http://localhost:8001

# MCP server endpoint (auto-configured in .mcp.json)
# MCP_PORT=8002

# Optional: Caido API key (generate in Caido UI → Settings → API Keys)
# CAIDO_API_KEY=your_caido_api_key_here
