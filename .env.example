ANTHROPIC_API_KEY=your_api_key_here

# Tester microservice URL (set automatically in Docker Compose)
# TOOL_RUNNER_URL=http://tester:8001

# Optional: Proxy settings (forwards through to tool execution)
# HTTP_PROXY=http://127.0.0.1:8080
# HTTPS_PROXY=http://127.0.0.1:8080

# Optional: Custom wordlists
# WORDLIST_DIR=/usr/share/wordlists

# Optional: Tool paths (only used when running CLI directly, not in Docker)
# NMAP_PATH=/usr/bin/nmap
# NIKTO_PATH=/usr/bin/nikto
# GOBUSTER_PATH=/usr/bin/gobuster
